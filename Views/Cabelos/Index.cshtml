                <td>A SM odiava ele demais, não sei nem como explicar esse ai kkk</td>
                <td>
                    <button>Aqui</button>
                </td>

            </tr>*@

            @foreach (Cabelos t in Model){
            <tr>
                <td>@t.Cor_do_Cabelo</td>
                <td>@t.Era</td>
