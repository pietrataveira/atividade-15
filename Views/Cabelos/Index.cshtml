@model List<Cabelos_do_Taeyong.Models.Cabelos>

<body>
    <h1>Cabelos do Taeyong</h1>
    <p>Total de Cabelos: @ViewBag.TotalCabelos</p>

    <a asp-controller="Cabelos" asp-action="Cadastro">Novo Cabelo</a>

    <table>
        <thead>
            <tr>
                <th>Cor do Cabelo</th>
                <th>Era</th>
                <th>Ano</th>
                <th>Nota</th>
                <th>Comentario</th>
                <th>Fotos</th>
            </tr>
        </thead>
